# Copy this file to .env and fill in the values

# Required
SECRET_KEY=change-me-to-a-random-64-char-hex-string
CLERK_SECRET_KEY=sk_test_from_clerk_dashboard
CLERK_PUBLISHABLE_KEY=pk_test_from_clerk_dashboard
CLERK_WEBHOOK_SECRET=whsec_from_clerk_webhook_settings
DATABASE_URL=postgresql+asyncpg://pixiserve:password@localhost:5432/pixiserve
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./data/photos

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Registration (set to false after creating admin user)
ALLOW_REGISTRATION=true

# Debug
DEBUG=true
